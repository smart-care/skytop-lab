# Skytop Lab — environment variables
# Copy this file to .env.local and fill in real values.
# NEVER commit .env.local. The hooks and gitleaks will block you if you try.

# --- Database (Neon) ---
# Use a connection string for the app_user role (SELECT/INSERT/UPDATE/DELETE only).
# For local dev, point this at your personal Neon dev branch, NOT production.
DATABASE_URL="postgresql://app_user:PASSWORD@HOST.neon.tech/skytop_lab?sslmode=require"

# Only set this when running drizzle-kit migrate. Uses the higher-privilege migration_user role.
# Leave unset in app runtime envs (Vercel). Lives in GitHub Actions secrets for CI migrations.
MIGRATION_DATABASE_URL=""

# --- Better Auth ---
# Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET="change-me-locally-and-rotate-in-prod"
BETTER_AUTH_URL="http://localhost:3000"

# --- Environment marker ---
# Used by the startup assertion to fail loud if the DB URL doesn't match the env.
# One of: development | preview | production
APP_ENV="development"
